# ──────────────────────────────────────────────────────────────
# Supabase – https://supabase.com/dashboard/project/_/settings/api
# ──────────────────────────────────────────────────────────────

# Your Supabase project URL
SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key (safe for server-side non-privileged queries)
SUPABASE_ANON_KEY=<your-anon-key>

# Service-role key — NEVER expose this to the browser or commit it.
# Used for privileged operations (sending magic links, admin queries).
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ──────────────────────────────────────────────────────────────
# Secrets for the application
# ──────────────────────────────────────────────────────────────
# OneMap API URL
ONEMAP_API_URL=<onemap-api-url>

# OneMap API Token
ONEMAP_API_TOKEN=<onemap-api-token>