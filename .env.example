# Next.js frontend
NEXT_PUBLIC_WORKER_URL=http://127.0.0.1:8787
NEXT_PUBLIC_KIOSK_LANG_DEFAULT=en
NEXT_PUBLIC_SCRIPTED_DEMO=true

# Worker secrets are configured separately with Wrangler.
# Copy workers/wrangler.toml.example to workers/wrangler.toml once Cloudflare resources exist.
# For OneMap live routing, keep credentials in Worker secrets, not frontend env:
#   cd workers
#   wrangler secret put ONEMAP_ACCESS_TOKEN
# or
#   wrangler secret put ONEMAP_EMAIL
#   wrangler secret put ONEMAP_PASSWORD
